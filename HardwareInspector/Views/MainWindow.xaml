<Window x:Class="HardwareInspector.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:HardwareInspector.ViewModels"
        xmlns:conv="clr-namespace:HardwareInspector.Converters"
        xmlns:models="clr-namespace:HardwareInspector.Models"
        Title="Hardware Inspector - 硬件检测工具"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <conv:TemperatureToColorConverter x:Key="TempToColor"/>
        <conv:LoadToColorConverter x:Key="LoadToColor"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
        <conv:BytesToReadableConverter x:Key="BytesToReadable"/>
        <conv:SensorTypeToIconConverter x:Key="SensorIcon"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>

        <Style x:Key="NavTabStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}" CornerRadius="6,6,0,0" Margin="2,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2D3D"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SensorBadge" TargetType="Border">
            <Setter Property="Background" Value="#1A2332"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <DataTemplate x:Key="SensorDataTemplate" DataType="{x:Type models:SensorData}">
            <Border Style="{StaticResource SensorBadge}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Type, Converter={StaticResource SensorIcon}}" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center">
                        <Run Text="{Binding Name, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontWeight="SemiBold" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center">
                        <Run Text="{Binding Value, Mode=OneWay, StringFormat={}{0:F1}}"/>
                        <Run Text="{Binding Unit, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🖥️" FontSize="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Hardware Inspector" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="硬件检测工具" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="🔄 刷新扫描" Command="{Binding RunScanCommand}"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" Padding="14,6" FontSize="12"/>
                    <Button Content="📄 导出TXT" Command="{Binding ExportTxtCommand}"
                            Style="{StaticResource ActionButton}" Margin="0,0,8,0" Padding="14,6" FontSize="12"/>
                    <Button Content="🌐 导出HTML" Command="{Binding ExportHtmlCommand}"
                            Style="{StaticResource ActionButton}" Padding="14,6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 - TabControl -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedPageIndex}"
                    Background="Transparent" BorderThickness="0" Margin="8"
                    Style="{StaticResource {x:Type TabControl}}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource NavTabStyle}"/>
                <Style TargetType="TabControl">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TabPanel Grid.Row="0" IsItemsHost="True" Background="{StaticResource SurfaceBrush}" Margin="8,8,8,0"/>
                                    <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="0,0,8,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,1,1">
                                        <ContentPresenter ContentSource="SelectedContent" Margin="16"/>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- 系统概览 -->
            <TabItem Header="📊 系统概览">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="实时传感器监控" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>

                        <UniformGrid Columns="4" Margin="0,0,0,20">
                            <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CPU 温度" Style="{StaticResource InfoLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CpuTemperature, StringFormat={}{0:F1}°C}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{Binding CpuTemperature, Converter={StaticResource TempToColor}}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="CPU 负载" Style="{StaticResource InfoLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CpuLoad, StringFormat={}{0:F1}%}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{Binding CpuLoad, Converter={StaticResource LoadToColor}}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="GPU 温度" Style="{StaticResource InfoLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding GpuTemperature, StringFormat={}{0:F1}°C}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{Binding GpuTemperature, Converter={StaticResource TempToColor}}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="4">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="内存使用" Style="{StaticResource InfoLabel}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MemoryUsagePercent, StringFormat={}{0:F1}%}" FontSize="30" FontWeight="Bold" HorizontalAlignment="Center"
                                               Foreground="{Binding MemoryUsagePercent, Converter={StaticResource LoadToColor}}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="系统信息" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
                        <UniformGrid Columns="3">
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="计算机名" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.ComputerName}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="操作系统" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.OperatingSystem}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="系统版本" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Style="{StaticResource InfoValue}">
                                    <Run Text="{Binding SystemSummary.OSVersion, Mode=OneWay}"/> Build <Run Text="{Binding SystemSummary.OSBuild, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="系统制造商" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.SystemManufacturer}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="系统型号" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.SystemModel}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="运行时间" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.Uptime}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="处理器" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.Processor}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="总物理内存" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.TotalPhysicalMemory}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,20,10">
                                <TextBlock Text="BIOS版本" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding SystemSummary.BIOSVersion}" Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- CPU -->
            <TabItem Header="🧠 CPU">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CpuList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:CpuInfo}">
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                                    <UniformGrid Columns="3" Margin="0,0,0,12">
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="架构" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Architecture}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="核心/线程" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Style="{StaticResource InfoValue}">
                                                <Run Text="{Binding CoreCount, Mode=OneWay}"/>C/<Run Text="{Binding ThreadCount, Mode=OneWay}"/>T
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="插槽" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Socket}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="最大频率" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Style="{StaticResource InfoValue}">
                                                <Run Text="{Binding MaxClockSpeed, Mode=OneWay}"/> MHz
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="当前频率" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Style="{StaticResource InfoValue}">
                                                <Run Text="{Binding CurrentClockSpeed, Mode=OneWay}"/> MHz
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="序列号" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding SerialNumber}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="虚拟化" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding VirtualizationEnabled}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="状态" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="传感器数据" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,8"
                                               Visibility="{Binding Sensors.Count, Converter={StaticResource CountToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Sensors}" ItemTemplate="{StaticResource SensorDataTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 主板 -->
            <TabItem Header="🔧 主板">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MotherboardList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MotherboardInfo}">
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                                    <UniformGrid Columns="3" Margin="0,0,0,12">
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="型号" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Model}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="版本" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Version}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="序列号" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding SerialNumber}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="BIOS版本" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding BIOSVersion}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="BIOS厂商" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding BIOSVendor}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="BIOS日期" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding BIOSDate}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="状态" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="传感器数据" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,8"
                                               Visibility="{Binding Sensors.Count, Converter={StaticResource CountToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Sensors}" ItemTemplate="{StaticResource SensorDataTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 内存 -->
            <TabItem Header="💾 内存">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MemoryList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MemoryInfo}">
                                <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8">
                                            <Run Text="{Binding BankLabel, Mode=OneWay}"/> - <Run Text="{Binding Manufacturer, Mode=OneWay}"/>
                                        </TextBlock>
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="型号" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding PartNumber}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="容量" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Capacity, Converter={StaticResource BytesToReadable}}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="类型" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding MemoryType}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="速度" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Style="{StaticResource InfoValue}">
                                                    <Run Text="{Binding Speed, Mode=OneWay}"/> MHz
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="电压" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Voltage}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="序列号" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding SerialNumber}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 显卡 -->
            <TabItem Header="🎮 显卡">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding GpuList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:GpuInfo}">
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                                    <UniformGrid Columns="3" Margin="0,0,0,12">
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="显存" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding DedicatedVRAM, Converter={StaticResource BytesToReadable}}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="驱动版本" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding DriverVersion}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="分辨率" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Style="{StaticResource InfoValue}">
                                                <Run Text="{Binding CurrentHorizontalResolution, Mode=OneWay}"/>x<Run Text="{Binding CurrentVerticalResolution, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="刷新率" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Style="{StaticResource InfoValue}">
                                                <Run Text="{Binding CurrentRefreshRate, Mode=OneWay}"/> Hz
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,8">
                                            <TextBlock Text="状态" Style="{StaticResource InfoLabel}"/>
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource InfoValue}"/>
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="传感器数据" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,8"
                                               Visibility="{Binding Sensors.Count, Converter={StaticResource CountToVis}}"/>
                                    <ItemsControl ItemsSource="{Binding Sensors}" ItemTemplate="{StaticResource SensorDataTemplate}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 硬盘 -->
            <TabItem Header="📀 硬盘">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DiskList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:DiskInfo}">
                                <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="容量" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Capacity, Converter={StaticResource BytesToReadable}}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="接口类型" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding InterfaceType}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="介质类型" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding MediaType}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="序列号" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding SerialNumber}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="固件版本" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding FirmwareRevision}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="分区数" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Partitions}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="文件系统" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding FileSystem}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="状态" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Status}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                        <TextBlock Text="传感器数据" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,8"
                                                   Visibility="{Binding Sensors.Count, Converter={StaticResource CountToVis}}"/>
                                        <ItemsControl ItemsSource="{Binding Sensors}" ItemTemplate="{StaticResource SensorDataTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 显示器 -->
            <TabItem Header="🖥️ 显示器">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding MonitorList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:MonitorInfo}">
                                <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8">
                                            <Run Text="{Binding Manufacturer, Mode=OneWay}"/> <Run Text="{Binding Model, Mode=OneWay}"/>
                                        </TextBlock>
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="型号" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Model}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="序列号" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding SerialNumber}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="生产年份" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding YearOfManufacture}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="生产周" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding WeekOfManufacture}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="分辨率" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Resolution}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 网卡 -->
            <TabItem Header="🌐 网卡">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NetworkList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:NetworkAdapterInfo}">
                                <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="MAC地址" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding MACAddress}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="速度" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Speed}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="IP地址" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding IPAddress}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="子网掩码" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding SubnetMask}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="默认网关" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding DefaultGateway}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="DNS服务器" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding DNSServers}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="DHCP" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Style="{StaticResource InfoValue}">
                                                    <Run Text="{Binding DHCPEnabled, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="连接状态" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding ConnectionStatus}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- 声卡 -->
            <TabItem Header="🔊 声卡">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SoundList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SoundCardInfo}">
                                <Border Background="#1A2332" CornerRadius="8" Padding="16" Margin="0,0,0,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,8"/>
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="制造商" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Manufacturer}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="驱动版本" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding DriverVersion}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="驱动日期" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding DriverDate}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="驱动提供商" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding DriverProvider}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,16,6">
                                                <TextBlock Text="状态" Style="{StaticResource InfoLabel}"/>
                                                <TextBlock Text="{Binding Status}" Style="{StaticResource InfoValue}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSensorRunning}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center">
                        <Run Text="传感器: "/>
                        <Run>
                            <Run.Style>
                                <Style TargetType="Run">
                                    <Setter Property="Text" Value="已停止"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSensorRunning}" Value="True">
                                            <Setter Property="Text" Value="运行中"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Run.Style>
                        </Run>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
